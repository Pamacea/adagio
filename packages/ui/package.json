{
  "name": "@adagio/ui",
  "version": "0.1.1",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./core": "./core/index.ts",
    "./core/*": "./core/*.ts",
    "./native": "./native/index.ts",
    "./native/*": "./native/*.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@adagio/types": "workspace:*",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "react": "^19.0.0",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@adagio/config": "workspace:*",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.17.10",
    "@types/react": "^19.0.6",
    "@types/react-dom": "^19.0.6",
    "@vitejs/plugin-react": "^4.3.4",
    "happy-dom": "^20.8.3",
    "jsdom": "^25.0.1",
    "next": "^15.1.4",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "peerDependencies": {
    "next": "^14.0.0 || ^15.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "tailwindcss": "^3.0.0"
  }
}
