{
  "name": "adagio",
  "version": "0.2.3",
  "private": true,
  "description": "Adagio - L'atlas harmonique intelligent pour guitaristes",
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@adagio/web",
    "dev:api": "turbo run dev --filter=@adagio/api",
    "dev:mobile": "turbo run dev --filter=@adagio/mobile",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json}\"",
    "db:generate": "pnpm --filter @adagio/database prisma generate",
    "db:push": "pnpm --filter @adagio/database prisma db push",
    "db:migrate": "pnpm --filter @adagio/database prisma migrate dev",
    "db:seed": "pnpm --filter @adagio/database tsx src/seed.ts",
    "db:studio": "pnpm --filter @adagio/database prisma studio"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "autoprefixer": "^10.4.27",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "next-auth": "^4.24.13"
  }
}
