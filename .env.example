# ============================================================================
# ADAGIO - Environment Variables Example
# ============================================================================
# Copy this file to .env.local and fill in your values

# ============================================================================
# DATABASE - Neon PostgreSQL
# ============================================================================
# Get your connection string from https://console.neon.tech
DATABASE_URL="postgresql://user:password@ep-cool-region.aws.neon.tech/adagio?sslmode=require"

# Direct Neon connection (optional, for Prisma Neon extensions)
# DIRECT_URL="postgresql://user:password@ep-cool-region.aws.neon.tech/adagio?sslmode=require"

# ============================================================================
# API - NestJS Backend
# ============================================================================
PORT=3001
NODE_ENV=development

# JWT Secret - Generate a random string with: openssl rand -base64 32
JWT_SECRET="change-me-in-production-use-openssl-rand-base64-32"
JWT_EXPIRES_IN="1h"
JWT_REFRESH_EXPIRES_IN="7d"

# BetterAuth
BETTER_AUTH_URL="http://localhost:3000"
BETTER_AUTH_SECRET="change-me-in-production"

# Allowed origins for CORS (comma-separated)
ALLOWED_ORIGINS="http://localhost:3000,https://adagio.vercel.app"

# ============================================================================
# WEB - Next.js Frontend
# ============================================================================
NEXT_PUBLIC_API_URL="http://localhost:3001/api/v1"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ============================================================================
# MOBILE - React Native (Expo)
# ============================================================================
EXPO_PUBLIC_API_URL="http://localhost:3001/api/v1"
EXPO_PUBLIC_APP_URL="exp://adagio"

# ============================================================================
# DEPLOYMENT - Production URLs
# ============================================================================
# Production API URL (Railway, Render, or your custom domain)
# NEXT_PUBLIC_API_URL="https://adagio-api.railway.app/api/v1"
# EXPO_PUBLIC_API_URL="https://adagio-api.railway.app/api/v1"