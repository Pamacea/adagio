{
  "name": "@adagio/database",
  "version": "0.1.1",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./prisma": "./prisma/schema.prisma"
  },
  "scripts": {
    "generate": "prisma generate",
    "push": "prisma db push",
    "migrate:dev": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "studio": "prisma studio",
    "seed": "tsx src/seed.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/adapter-neon": "^5.22.0",
    "@prisma/client": "^5.22.0",
    "@prisma/extension-accelerate": "^1.2.0"
  },
  "devDependencies": {
    "@adagio/config": "workspace:*",
    "@adagio/types": "workspace:*",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
