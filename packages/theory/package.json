{
  "name": "@adagio/theory",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./core/*": {
      "types": "./dist/core/*.d.ts",
      "import": "./dist/core/*.js"
    },
    "./calculators/*": {
      "types": "./dist/calculators/*.d.ts",
      "import": "./dist/calculators/*.js"
    },
    "./mappings/*": {
      "types": "./dist/mappings/*.d.ts",
      "import": "./dist/mappings/*.js"
    },
    "./fretboard/*": {
      "types": "./dist/fretboard/*.d.ts",
      "import": "./dist/fretboard/*.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest"
  },
  "dependencies": {
    "@adagio/types": "workspace:*",
    "tonal": "^6.4.3"
  },
  "devDependencies": {
    "@adagio/config": "workspace:*",
    "tsup": "^8.5.1",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
