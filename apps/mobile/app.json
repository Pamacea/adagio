{
  "expo": {
    "name": "Adagio",
    "slug": "adagio",
    "version": "0.2.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a05"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "bundleIdentifier": "com.adagio.app"
    },
    "android": {
      "package": "com.adagio.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0a05"
      }
    },
    "plugins": [
      "expo-router",
      "expo-splash-screen",
      "expo-status-bar",
      [
        "expo-sqlite",
        {
          "enableDatabase": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      }
    }
  }
}
