# ============================================================================
# ENVIRONMENT VARIABLES - Adagio Mobile
# ============================================================================

# ----------------------------------------------------------------------------
# API URL
# ----------------------------------------------------------------------------
# API base URL - use your local IP for development with physical devices
# For emulator: http://localhost:3001/api/v1
# For physical device: http://192.168.x.x:3001/api/v1
EXPO_PUBLIC_API_URL="http://localhost:3001/api/v1"

# ----------------------------------------------------------------------------
# APP CONFIG
# ----------------------------------------------------------------------------
EXPO_PUBLIC_APP_NAME="Adagio"
EXPO_PUBLIC_APP_VERSION="0.1.1"

# ----------------------------------------------------------------------------
# FEATURE FLAGS
# ----------------------------------------------------------------------------
EXPO_PUBLIC_ENABLE_ANALYTICS="false"
EXPO_PUBLIC_ENABLE_NOTIFICATIONS="false"
EXPO_PUBLIC_ENABLE_HAPTICS="true"

# ----------------------------------------------------------------------------
# DEVELOPMENT
# ----------------------------------------------------------------------------
# Enable devtools for development
EXPO_PUBLIC_DEVTOOLS_ENABLED="true"
