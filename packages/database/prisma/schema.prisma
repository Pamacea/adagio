// ============================================================================
// PRISMA SCHEMA - Adagio Database
// ============================================================================

generator client {
  provider        = "prisma-client-js"
  binaryTargets   = ["native", "darwin-arm64"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// AUTHENTICATION & USERS
// ============================================================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified Boolean   @default(false)
  password      String?   // For credential authentication
  name          String    @default("")
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  accounts         Account[]
  sessions         Session[]
  progressions     Progression[]
  progress         UserProgress[]
  preferences      UserPreferences?
  userAchievements UserAchievement[]
  lessonProgress   LessonProgress[]
  practiceSessions PracticeSession[]
  syncLogs         SyncLog[]

  @@map("users")
}

model Account {
  id                      String   @id @default(cuid())
  userId                  String
  providerId              String
  accountId               String
  accessToken             String?  @db.Text
  refreshToken            String?  @db.Text
  idToken                 String?  @db.Text
  accessTokenExpiresAt    DateTime?
  refreshTokenExpiresAt   DateTime?
  scope                   String?
  password                String?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@map("accounts")
}

model Session {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

// Better-auth compatible verification model
model verification {
  id         String    @id @default(cuid())
  identifier String    @unique
  value      String    @db.Text
  expiresAt  DateTime
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@map("verification_tokens")
}

// ============================================================================
// USER PREFERENCES & PROGRESS
// ============================================================================

model UserPreferences {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Display preferences
  theme           String   @default("midnight")
  showIntervals   Boolean  @default(true)
  showNotes       Boolean  @default(true)
  showDegrees     Boolean  @default(false)

  // Instrument preferences
  tuning          String   @default("EADGBE")
  fretCount       Int      @default(24)

  // Audio preferences
  volume          Float    @default(0.7)
  metronomeVolume Float    @default(0.5)

  // Gamification
  totalXP         Int      @default(0)
  level           Int      @default(1)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("user_preferences")
}

model UserProgress {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Progress tracking
  techniqueId     String
  technique       Technique @relation(fields: [techniqueId], references: [id], onDelete: Cascade)
  status          String   @default("locked") // locked, in-progress, learned, mastered
  xp              Int      @default(0)
  practiceCount   Int      @default(0)
  totalPracticeTime Int    @default(0) // in minutes
  lastPracticed   DateTime?
  milestonesCompleted Json   // Array of milestone IDs

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([userId, techniqueId])
  @@map("user_progress")
}

// ============================================================================
// MUSIC THEORY CONTENT
// ============================================================================

model Mode {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String   // ex: "Dorien"
  intervals   String   @db.Text // JSON array: [1, 2, b3, 4, 5, 6, b7]

  // Emotional mapping
  character   String   @db.Text // ex: "Aérien / Lumineux"
  sensation   String   @db.Text // ex: "Jazzy, Chaud"
  feeling     String?  // ex: "Féerique"

  // Theory
  greekName   String?  // ex: "Dorian"
  relativeTo  String?  // ex: "ii in major"
  axisGroup   String?  // ex: "tonic", "dominant", "subdominant"

  // Advice
  advice      String?  @db.Text

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("modes")
}

model Scale {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String   // ex: "Pentatonique Mineure"
  root        String   // Default root for display
  intervals   String   @db.Text
  type        String   // scale, mode
  quality     String   // major, minor, pentatonic, blues

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("scales")
}

model Chord {
  id          String   @id @default(cuid())
  name        String   // ex: "Cmaj7"
  root        String   // ex: "C"
  quality     String   // ex: "maj7", "m7", "7"
  intervals   String   @db.Text
  extensions  String?  @db.Text // JSON: ["9", "11"]

  // Fingerings stored as JSON
  fingerings  Json     // Array of fretboard positions

  // Theory
  tension     String?  // stable, tense, dominant, dissonant

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([root, quality])
  @@map("chords")
}

// ============================================================================
// PROGRESSIONS & ANALYSIS
// ============================================================================

model Progression {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  name        String?
  key         String   // ex: "C"
  timeSignature String @default("4/4")
  chords      Json     // Array of chord symbols/degrees
  analysis    Json?    // Analysis results (suggested scales, etc.)

  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("progressions")
}

model HarmonyRule {
  id          String   @id @default(cuid())
  degree      String   // ex: "I", "IV", "v"
  tonality    String   // ex: "major", "minor"
  sensation   String   @db.Text // ex: "Être content à la maison"
  advice      String?  @db.Text

  @@unique([degree, tonality])
  @@map("harmony_rules")
}

// ============================================================================
// TECHNIQUES & KNOWLEDGE BASE
// ============================================================================

model Technique {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String   // ex: "Hammer-on"
  category    String   // legato, sweep, tapping, etc.
  difficulty  String   // beginner, intermediate, advanced
  description String?  @db.Text

  // Visual aids
  diagramUrl  String?
  videoUrl    String?
  audioExample String?

  // Notation & tips
  notation    String?  @db.Text
  tips        Json?    // Array of tips

  // Prerequisites
  prerequisites Json?   // Array of technique IDs
  relatedTechniques Json? // Array of related technique IDs
  estimatedPracticeTime Int? // in hours

  // Milestones
  milestones  Json?    // Array of milestone objects

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  progress    UserProgress[]

  @@map("techniques")
}

// ============================================================================
// AXIS THEORY
// ============================================================================

model AxisGroup {
  id          String   @id @default(cuid())
  name        String   // tonic, dominant, subdominant
  notes       Json     // Array of note names
  description String   @db.Text
  substitutions Json   // Array of substitution types

  @@unique([name])
  @@map("axis_groups")
}

// ============================================================================
// ACHIEVEMENTS & GAMIFICATION
// ============================================================================

model SyncLog {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Sync details
  deviceType  String   // web, mobile
  deviceId    String?
  action      String   // pull, push, full
  status      String   // success, conflict, error

  // Items synced
  itemsCount  Int      @default(0)

  // Timestamps
  syncedAt    DateTime @default(now())

  @@index([userId, syncedAt])
  @@map("sync_logs")
}

// ============================================================================
// ACHIEVEMENTS SYSTEM
// ============================================================================

model Achievement {
  id          String   @id @default(cuid())
  slug        String   @unique // ex: 'first-riff', 'streak-7'
  title       String   // ex: 'Premier Riff', 'Semaine de Fer'
  description String   @db.Text
  category    String   // progression, discovery, practice, mastery, social, milestone
  xp          Int      @default(0)
  target      Int      // Target value to unlock
  rarity      String   @default("common") // common, rare, epic, legendary
  icon        String?  // Icon name or emoji

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  userAchievements UserAchievement[]

  @@map("achievements")
}

model UserAchievement {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievementId String
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  // Progress tracking
  progress      Int      @default(0)
  target        Int
  unlockedAt    DateTime?
  completedAt   DateTime?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userId, achievementId])
  @@index([userId])
  @@map("user_achievements")
}

// ============================================================================
// LESSONS & LEARNING
// ============================================================================

model Lesson {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String?  @db.Text
  category    String   // THEORY, FRETBOARD, CHORDS, NOTATION, PROGRESSIONS, COMPOSITION
  level       String   // BEGINNER, INTERMEDIATE, ADVANCED
  duration    Int      // in minutes
  xp          Int      @default(0)

  // Content stored as JSON for flexibility
  topics      Json?    // Array of topic strings
  content     Json?    // Structured lesson content

  // Metadata
  isPublished Boolean  @default(true)
  order       Int      @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  progress    LessonProgress[]

  @@map("lessons")
}

model LessonProgress {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonId    String
  lesson      Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  // Progress tracking
  status      String   @default("not-started") // not-started, in-progress, completed
  completedSections Json // Array of completed section IDs
  currentSection Int  @default(0)
  xp          Int      @default(0)

  // Timestamps
  startedAt   DateTime?
  completedAt DateTime?
  lastAccessed DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, lessonId])
  @@index([userId])
  @@map("lesson_progress")
}

// ============================================================================
// PRACTICE SESSIONS
// ============================================================================

model PracticeSession {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Session details
  date        DateTime @default(now())
  duration    Int      // in minutes
  techniqueId String?

  // Metrics
  averageBPM  Int?
  quality     String?  // needs-work, good, excellent

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId, date])
  @@map("practice_sessions")
}
